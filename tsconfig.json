{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    /* rootDir is essential for NestJS to map the src folder correctly */
    "rootDir": "src",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,

    /* NESTJS/SWAGGER SUPPORT */
    "strictPropertyInitialization": false,
    "paths": {
      /* Without baseUrl, we point directly to the src folder relative to this file */
      "@/*": ["./src/*"]
    },

    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "public", "**/*.spec.ts"]
}